# Which AI provider api/_lib/providers/index.js should use.
AI_PROVIDER=gemini

# Server-side only — never exposed to the client. Get one at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: use a model with a more permissive free-tier quota.
GEMINI_MODEL=gemini-1.5-flash

# OpenRouter provider (alternative to Gemini)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
